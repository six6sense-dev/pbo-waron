# ===== PILIH MODE DATABASE =====

# MODE 1: In-Memory Database (PRODUCTION - Vercel Recommended) ✅
# Data tidak disimpan lokal, hanya di RAM untuk session execution
# Cocok untuk Vercel serverless: cepat, aman, tanpa file storage
USE_IN_MEMORY_DB=true

# MODE 2: Local Database File (DEVELOPMENT)
# Data disimpan di data-local.json
# Gunakan ini untuk development lokal
# USE_LOCAL_DB=true

# MODE 3: Google Sheets (Optional - untuk enterprise)
# Data di Google Sheets, perlu setup Google Cloud
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...
# GOOGLE_PRIVATE_KEY=...
# GOOGLE_SPREADSHEET_ID=...

# ===== KONFIGURASI UMUM =====
GOOGLE_DRIVE_FOLDER_ID=
JWT_SECRET=replace-with-strong-random-secret-min-32-chars
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123


